DOMAIN=schedule.example.com
LETSENCRYPT_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password
# Generate with e.g.: openssl rand -base64 48
JWT_SECRET=change-me-too
JWT_EXPIRE_MINUTES=720
# Optional: used to build public iCal subscription URLs (recommended for production behind HTTPS).
# Domain setup (this repo uses /api): https://schedule.example.com/api
# IP-only setup: http://SERVER_IP:8000
PUBLIC_BASE_URL=
# Optional: frontend base URL used for PDF rendering (Playwright).
# Domain setup: https://schedule.example.com
# IP-only setup: http://SERVER_IP
FRONTEND_BASE_URL=

# --- Agent solver (optional; only needed for solver_mode="agent") ---
# Everything here can also be set at runtime by an admin in Settings ->
# Solver; values stored there override these env defaults.
# API key for the Anthropic provider. Without it, agent runs fall back to the
# heuristic seed plan with an explanatory note.
ANTHROPIC_API_KEY=
# anthropic | openai (OpenAI-compatible, e.g. self-hosted vLLM) | mock (tests)
AGENT_PROVIDER=anthropic
# Anthropic model id; ignored when the admin picked one in Settings.
AGENT_MODEL=claude-sonnet-5
# OpenAI-compatible endpoint (AGENT_PROVIDER=openai), e.g. a self-hosted vLLM:
#   OPENAI_BASE_URL=http://10.0.0.5:8000/v1
# Most self-hosted servers ignore the key; leave empty unless yours checks it.
# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# LLM round-trips per solve; wall clock is additionally capped by the
# request's timeout_seconds (default 300s for agent mode).
AGENT_MAX_ITERATIONS=20
# AGENT_MAX_TOKENS=8000
# Tests only: path to a scripted mock-provider JSON (AGENT_PROVIDER=mock).
# AGENT_MOCK_SCRIPT=
