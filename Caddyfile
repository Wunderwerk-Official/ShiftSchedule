# The app moved to shiftplanner.truhn.ai (2026-07). This server only issues
# permanent redirects now — paths are preserved, so bookmarks, iCal
# subscription URLs and published web links keep working through the
# redirect (their tokens were migrated with the database). The tls directive
# stays so the certificate keeps renewing for the redirect itself.
{$DOMAIN} {
  redir https://shiftplanner.truhn.ai{uri} permanent
  tls {$LETSENCRYPT_EMAIL}
}
